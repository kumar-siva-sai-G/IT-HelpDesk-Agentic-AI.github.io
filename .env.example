# ── LLM ────────────────────────────────────────────────
GROQ_API_KEY=# fill this
GROQ_MODEL=llama3-8b-8192

# ── Telegram ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=# fill this
TELEGRAM_ADMIN_CHAT_ID=# fill this

# ── Memory ──────────────────────────────────────────────
MEM0_API_KEY= # fill this   # optional: leave blank for local mode

# ── Paths ───────────────────────────────────────────────
CHROMA_DB_PATH=./kb/chroma_store
SQLITE_DB_PATH=./tickets.db

# ── SLA ─────────────────────────────────────────────────
SLA_MINUTES=10
HIGH_PRIORITY_KEYWORDS=exam,production,critical,urgent,down,emergency

# ── System tools ────────────────────────────────────────
ALLOW_REAL_SYSTEM_COMMANDS= true   # set true for live deployment
